*.swp
*~

# Streamlit local secrets
.streamlit/secrets.toml

# Test / E2E isolation (never commit)
.pytest_chroma/
.e2e_chroma/
.pytest_logs/

# Screenshot scratch dirs + raw playwright captures
# (annotated PNGs under docs/*/ are the actual committed evidence)
.screenshot_chroma/
.screenshot_data/
.screenshot_logs/
docs/use-mode-evidence/raw/

# Runtime logs (committed evidence lives under logs/samples/)
logs/run_*.jsonl
logs/llm_calls.jsonl
!logs/samples/

# PO/client source material — kept local only, never committed
PO_requirements/

# Local copy of PO messages at repo root
/PO_message_history/

# Cursor helper script (local workflow only)
scripts/cursor-request-validation.sh

# Local dev tooling for evidence-asset generation (kept locally for re-runs;
# the committed deliverables are the resulting MP4s under demos/ and the
# annotated PNGs under docs/use-mode-evidence/).
scripts/demos/record_walkthroughs.py
scripts/screenshots/capture_use_mode.py
scripts/screenshots/annotate_use_mode.py
scripts/generate_demo_placeholders.sh


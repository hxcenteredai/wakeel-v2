# Wakeel environment configuration
# Copy to `.env` and fill in real values locally. NEVER commit `.env`.

# --- LLM endpoint (OpenAI-protocol compatible) ---
# Provider-agnostic per SOW Section 6: same code, swap endpoint via these vars.
#
#   Developer / dev environment (OpenAI direct):
#     OPENAI_BASE_URL=https://api.openai.com/v1
#     OPENAI_API_KEY=<your OpenAI direct key>
#
#   Compass verification (UAE, client-side only — model IDs confirmed available):
#     OPENAI_BASE_URL=https://api.core42.ai/v1
#     OPENAI_API_KEY=<kept on the client side>
#   Note: use the api.* subdomain (the API endpoint per the Compass User Guide).
#   compass.core42.ai is the web UI, not the API.
#
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.core42.ai/v1   # (active default)
# OPENAI_BASE_URL=https://api.openai.com/v1   # (commented dev alt)

# --- Model selection by tier (confirmed available on Compass) ---
DEFAULT_MODEL=gpt-4.1
REASONING_MODEL=gpt-5.1
EMBEDDING_MODEL=text-embedding-3-large

# Optional: dedicated Arabic model for the Interviewer, set per-agent via env only.
# On Compass, the sovereign-AI demo uses Inception MSA:
#   INTERVIEWER_MODEL=G42-INCEPTION-GPT41-MSA
# If unset, the Interviewer uses DEFAULT_MODEL with Arabic-aware prompting.
INTERVIEWER_MODEL=

# --- Legacy dev-only quota brake (NOT used against Compass) ---
# Historically capped per-request token usage for OpenAI-direct development
# keys. Compass enforces quotas at the group level, so this flag no longer
# alters wire behaviour — kept here only for back-compat surfacing in
# `current_config()`. Leave `false` for acceptance / production runs.
SAMPLE_MODE=false

# When true (or when OPENAI_API_KEY is empty), the LLM wrapper returns
# deterministic stub responses instead of calling the network. Lets the full
# graph, loops, UI, and audit logs run without credentials or quota usage.
OFFLINE_MODE=false

# --- Service wiring ---
# Backend URL the Streamlit UI calls.
WAKEEL_BACKEND_URL=http://localhost:8000

# --- Vector store ---
CHROMA_DIR=./data/chroma
CORPUS_CONFIG=./data/corpus/corpus_config.json

# --- Logging ---
LOG_DIR=./logs
